{
  "expo": {
    "name": "CSA Congresso 2026",
    "slug": "csa-congresso-2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/csa-logo.png",
    "scheme": "csa-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/csa-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A3A6E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.csa.congresso2026"
    },
    "android": {
      "package": "com.csa.congresso2026",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/csa-logo.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://xrpquuklhungyvctmpch.supabase.co"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Permita o acesso à câmara para ler QR Codes e marcar a presença dos participantes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "d19afac1-cfec-4f51-9861-21a36c5e7faf"
      }
    },
    "owner": "osvaldo.queta"
  }
}
